{
  "hooks": {
    "PreToolUse": [
      {
        "command": "scripts/audit_pre_tool_use.sh",
        "args": ["--mode=structured"],
        "timeout": 10,
        "matcher": "shell|file_write"
      },
      {
        "command": "echo '[hook] pre-tool-use'"
      }
    ],
    "PostToolUse": [
      {
        "command": "scripts/audit_post_tool_use.sh",
        "args": ["--emit-otlp"],
        "timeout": 5
      }
    ],
    "Stop": [
      {
        "command": "scripts/cleanup_artifacts.sh"
      }
    ]
  }
}
