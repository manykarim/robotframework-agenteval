# agenteval env vars — copy to .env and customize.
# Naming: AGENTEVAL_<KEY> per architecture.md §Configuration Parameter Naming.
# Precedence: kwarg → env var → .env file → defaults (FR41).
#
# Boolean parsing (Story 1b.1): bool-typed env-vars accept the
# case-insensitive set {true, false, 1, 0, yes, no, on, off}. Anything else
# raises ValueError at AgentEval() construction.
#
# Quoted values + `export` prefix: `_load_dotenv` strips surrounding matching
# quotes (`"value"` / `'value'`) and an optional `export ` prefix (common in
# shell-sourced .env files). Inline `#` comments after a value are NOT
# supported (the value goes to end-of-line).
#
# Unknown AGENTEVAL_* keys are emitted as UserWarning at AgentEval()
# construction so typos like `AGENTEVAL_PROVDER` surface visibly.

# Provider selection (FR42 default: litellm)
AGENTEVAL_PROVIDER=litellm

# Telemetry (FR42 default: true; FR44 disable via false)
AGENTEVAL_TELEMETRY=true

# Trace backend (FR33b: memory | jsonl Phase 1; otlp Phase 2)
AGENTEVAL_TRACE_BACKEND=memory

# MCP per-test scope (FR42 + ADR-009 default: true). Valid values:
#   true  = per-test isolation (default; correct under pabot --processes N parallel)
#   suite = per-suite scope (recipe-5 dogfood-CI override; documented trade-off per ADR-009 + architecture L410)
#   false = single shared instance across all tests (heaviest pollution risk; only correct under serial execution)
# Story 1a.1 baseline drifted to `=suite` — corrected 2026-05-18 by Story 1a.6 pre-create-story
# ratification to match PRD FR42 + ADR-009 ratified default.
AGENTEVAL_MCP_PER_TEST=true

# Validate operator gate (FR42 default: false; FR43 explicit opt-in)
AGENTEVAL_ALLOW_VALIDATE_OPERATOR=false

# Cost guardrail in USD (FR42 default: 5.0; @guarded_fanout per ADR-015 (was ADR-A5))
AGENTEVAL_MAX_COST_USD=5.0

# Default provider temperature (FR42 default: 0.0). Added 2026-05-18 by Story 1b.1
# pre-create-story drift check — FR42 listed default_temperature in PRD but
# .env.example was incomplete. Story 1b.1 _kernel/context.py FR41 wiring reads this.
AGENTEVAL_DEFAULT_TEMPERATURE=0.0

# Tier-3 fan-out wall-clock budget in seconds (FR11b default: empty = no cap;
# opt-in via explicit value). @guarded_fanout per ADR-015. Added 2026-05-18 by
# Story 1b.1 pre-create-story drift check for FR41 completeness.
AGENTEVAL_MAX_RUNTIME_SECONDS=

# External-MCP coverage gate (ADR-016 default-deny; set true to allow external_mixed runs)
AGENTEVAL_ALLOW_EXTERNAL_MCP_BLIND=false
