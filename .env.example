# agenteval env vars — copy to .env and customize.
# Naming: AGENTEVAL_<KEY> per architecture.md §Configuration Parameter Naming.
# Precedence: kwarg → env var → .env file → defaults (FR41).

# Provider selection (FR42 default: litellm)
AGENTEVAL_PROVIDER=litellm

# Telemetry (FR42 default: true; FR44 disable via false)
AGENTEVAL_TELEMETRY=true

# Trace backend (FR33b: memory | jsonl Phase 1; otlp Phase 2)
AGENTEVAL_TRACE_BACKEND=memory

# MCP per-test scope (FR40: test | suite | process; FR42 default: suite)
AGENTEVAL_MCP_PER_TEST=suite

# Validate operator gate (FR42 default: false; FR43 explicit opt-in)
AGENTEVAL_ALLOW_VALIDATE_OPERATOR=false

# Cost guardrail in USD (FR42 default: 5.0; @guarded_fanout per ADR-A5)
AGENTEVAL_MAX_COST_USD=5.0

# External-MCP coverage gate (ADR-016 default-deny; set true to allow external_mixed runs)
AGENTEVAL_ALLOW_EXTERNAL_MCP_BLIND=false
